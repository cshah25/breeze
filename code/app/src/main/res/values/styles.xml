<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="CircleImage" parent="">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">50%</item>
    </style>

    <style name="RoundedCorners.EventDetails" parent="">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">32dp</item>
    </style>

    <style name="RoundedCorners.ExploreEventEntry" parent="">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">20dp</item>
    </style>

    <style name="RoundedCorners.OrganizeEventEntry" parent="">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">14dp</item>
    </style>

    <style name="ShapeAppearance.Breezeseas.Dialog" parent="">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">@dimen/dialog_corner_radius</item>
    </style>

    <style name="TextAppearance.Breezeseas.BottomNavigation" parent="TextAppearance.Material3.LabelSmall">
        <item name="android:fontFamily">@font/inter_medium</item>
        <item name="fontFamily">@font/inter_medium</item>
        <item name="android:textSize">@dimen/bottom_nav_label_text_size</item>
        <item name="android:includeFontPadding">false</item>
        <item name="android:maxLines">1</item>
        <item name="android:ellipsize">end</item>
        <item name="android:gravity">center</item>
        <item name="android:letterSpacing">0</item>
    </style>

    <style name="TextAppearance.Breezeseas.TicketsTab" parent="TextAppearance.Material3.LabelLarge">
        <item name="android:fontFamily">@font/inter_semibold</item>
        <item name="fontFamily">@font/inter_semibold</item>
        <item name="android:textSize">12sp</item>
        <item name="android:includeFontPadding">false</item>
        <item name="android:textAllCaps">false</item>
    </style>

    <style name="TextAppearance.Breezeseas.ScreenTitle" parent="TextAppearance.Material3.DisplaySmall">
        <item name="android:fontFamily">@font/inter_semibold</item>
        <item name="fontFamily">@font/inter_semibold</item>
        <item name="android:textSize">30sp</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:includeFontPadding">false</item>
        <item name="android:letterSpacing">0</item>
    </style>

    <style name="TextAppearance.Breezeseas.ScreenSubtitle" parent="TextAppearance.Material3.BodyLarge">
        <item name="android:fontFamily">@font/inter_regular</item>
        <item name="fontFamily">@font/inter_regular</item>
        <item name="android:textSize">15sp</item>
        <item name="android:textColor">@color/text_secondary</item>
        <item name="android:includeFontPadding">false</item>
        <item name="android:lineSpacingExtra">2dp</item>
    </style>

    <style name="TextAppearance.Breezeseas.SectionLabel" parent="TextAppearance.Material3.LabelLarge">
        <item name="android:fontFamily">@font/inter_medium</item>
        <item name="fontFamily">@font/inter_medium</item>
        <item name="android:textSize">13sp</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:includeFontPadding">false</item>
    </style>

    <style name="TextAppearance.Breezeseas.CardTitle" parent="TextAppearance.Material3.TitleLarge">
        <item name="android:fontFamily">@font/inter_semibold</item>
        <item name="fontFamily">@font/inter_semibold</item>
        <item name="android:textSize">20sp</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:includeFontPadding">false</item>
        <item name="android:lineSpacingExtra">1dp</item>
    </style>

    <style name="TextAppearance.Breezeseas.SurfaceChip" parent="TextAppearance.Material3.LabelMedium">
        <item name="android:fontFamily">@font/inter_medium</item>
        <item name="fontFamily">@font/inter_medium</item>
        <item name="android:textSize">11sp</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:includeFontPadding">false</item>
        <item name="android:letterSpacing">0.01</item>
    </style>

    <style name="TextAppearance.Breezeseas.DialogTitle" parent="TextAppearance.Material3.TitleLarge">
        <item name="android:fontFamily">@font/inter_semibold</item>
        <item name="fontFamily">@font/inter_semibold</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textSize">24sp</item>
    </style>

    <style name="TextAppearance.Breezeseas.DialogBody" parent="TextAppearance.Material3.BodyMedium">
        <item name="android:fontFamily">@font/inter_regular</item>
        <item name="fontFamily">@font/inter_regular</item>
        <item name="android:textColor">@color/text_secondary</item>
        <item name="android:textSize">14sp</item>
        <item name="android:lineSpacingExtra">2dp</item>
    </style>

    <style name="Widget.Breezeseas.ProfileTextInput" parent="Widget.Material3.TextInputLayout.FilledBox.Dense">
        <item name="boxBackgroundMode">none</item>
        <item name="hintTextColor">@color/text_secondary</item>
        <item name="android:textColorHint">@color/text_secondary</item>
        <item name="android:paddingTop">0dp</item>
        <item name="android:paddingBottom">0dp</item>
    </style>

    <style name="Widget.Breezeseas.Button.Base" parent="Widget.Material3.Button">
        <item name="android:fontFamily">@font/inter_medium</item>
        <item name="fontFamily">@font/inter_medium</item>
        <item name="android:textAllCaps">false</item>
        <item name="cornerRadius">@dimen/button_corner_radius</item>
        <item name="android:minHeight">@dimen/button_height</item>
        <item name="android:textSize">15sp</item>
        <item name="android:paddingStart">18dp</item>
        <item name="android:paddingEnd">18dp</item>
        <item name="elevation">0dp</item>
    </style>

    <style name="Widget.Breezeseas.Button.Primary" parent="Widget.Breezeseas.Button.Base">
        <item name="android:fontFamily">@font/inter_semibold</item>
        <item name="fontFamily">@font/inter_semibold</item>
        <item name="backgroundTint">@color/black</item>
        <item name="android:textColor">@color/white</item>
        <item name="rippleColor">@color/ripple_light</item>
    </style>

    <style name="Widget.Breezeseas.Button.Secondary" parent="Widget.Breezeseas.Button.Base">
        <item name="backgroundTint">@color/white</item>
        <item name="strokeColor">@color/grey_border</item>
        <item name="strokeWidth">1dp</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="rippleColor">@color/ripple_dark</item>
    </style>

    <style name="Widget.Breezeseas.Button.Destructive" parent="Widget.Breezeseas.Button.Base">
        <item name="backgroundTint">@color/destructive_surface</item>
        <item name="strokeColor">@color/destructive_stroke</item>
        <item name="strokeWidth">1dp</item>
        <item name="android:textColor">@color/comment_delete</item>
        <item name="rippleColor">@color/ripple_dark</item>
    </style>

    <style name="ThemeOverlay.Breezeseas.MaterialAlertDialog" parent="ThemeOverlay.Material3.MaterialAlertDialog">
        <item name="backgroundTint">@color/white</item>
        <item name="colorPrimary">@color/black</item>
        <item name="colorOnSurface">@color/text_primary</item>
        <item name="materialAlertDialogTitleTextStyle">@style/TextAppearance.Breezeseas.DialogTitle</item>
        <item name="materialAlertDialogBodyTextStyle">@style/TextAppearance.Breezeseas.DialogBody</item>
        <item name="shapeAppearanceOverlay">@style/ShapeAppearance.Breezeseas.Dialog</item>
    </style>

    <style name="ThemeOverlay.Breezeseas.DateRangePicker" parent="ThemeOverlay.Material3.MaterialCalendar">
        <item name="colorPrimary">@color/black</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorSurface">@color/white</item>
        <item name="colorOnSurface">@color/text_primary</item>
        <item name="colorOnSurfaceVariant">@color/text_secondary</item>
        <item name="colorOutline">@color/grey_border</item>
    </style>

</resources>
