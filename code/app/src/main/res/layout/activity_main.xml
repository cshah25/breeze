<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/main"
    android:background="@android:color/white"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <FrameLayout
        android:id="@+id/fragment_container"
        android:background="@android:color/white"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <LinearLayout
        android:id="@+id/bottom_navigation"
        android:layout_width="0dp"
        android:layout_height="@dimen/bottom_nav_height"
        android:minHeight="@dimen/bottom_nav_height"
        android:layout_marginStart="@dimen/bottom_nav_horizontal_margin"
        android:layout_marginEnd="@dimen/bottom_nav_horizontal_margin"
        android:layout_marginBottom="@dimen/bottom_nav_bottom_margin"
        android:background="@drawable/bg_tickets_tab_shell"
        android:elevation="8dp"
        android:orientation="vertical"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingStart="@dimen/bottom_nav_padding_horizontal"
            android:paddingEnd="@dimen/bottom_nav_padding_horizontal">

            <FrameLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1">

                <LinearLayout
                    android:id="@+id/nav_explore"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:background="@drawable/bg_bottom_nav_item"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="?attr/selectableItemBackgroundBorderless"
                    android:gravity="center"
                    android:minWidth="@dimen/bottom_nav_item_min_width"
                    android:minHeight="@dimen/bottom_nav_item_min_height"
                    android:orientation="vertical"
                    android:paddingStart="@dimen/bottom_nav_item_padding_horizontal"
                    android:paddingTop="@dimen/bottom_nav_item_padding_vertical"
                    android:paddingEnd="@dimen/bottom_nav_item_padding_horizontal"
                    android:paddingBottom="@dimen/bottom_nav_item_padding_vertical">

                    <ImageView
                        android:layout_width="@dimen/bottom_nav_icon_size"
                        android:layout_height="@dimen/bottom_nav_icon_size"
                        android:duplicateParentState="true"
                        android:src="@drawable/ic_explore"
                        android:tint="@color/nav_item_color" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="3dp"
                        android:duplicateParentState="true"
                        android:text="Explore"
                        android:textAppearance="@style/TextAppearance.Breezeseas.BottomNavigation"
                        android:textColor="@color/nav_item_color" />
                </LinearLayout>
            </FrameLayout>

            <FrameLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1">

                <LinearLayout
                    android:id="@+id/nav_tickets"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:background="@drawable/bg_bottom_nav_item"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="?attr/selectableItemBackgroundBorderless"
                    android:gravity="center"
                    android:minWidth="@dimen/bottom_nav_item_min_width"
                    android:minHeight="@dimen/bottom_nav_item_min_height"
                    android:orientation="vertical"
                    android:paddingStart="@dimen/bottom_nav_item_padding_horizontal"
                    android:paddingTop="@dimen/bottom_nav_item_padding_vertical"
                    android:paddingEnd="@dimen/bottom_nav_item_padding_horizontal"
                    android:paddingBottom="@dimen/bottom_nav_item_padding_vertical">

                    <ImageView
                        android:layout_width="@dimen/bottom_nav_icon_size"
                        android:layout_height="@dimen/bottom_nav_icon_size"
                        android:duplicateParentState="true"
                        android:src="@drawable/ic_ticket"
                        android:tint="@color/nav_item_color" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="3dp"
                        android:duplicateParentState="true"
                        android:text="Tickets"
                        android:textAppearance="@style/TextAppearance.Breezeseas.BottomNavigation"
                        android:textColor="@color/nav_item_color" />
                </LinearLayout>
            </FrameLayout>

            <FrameLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1">

                <LinearLayout
                    android:id="@+id/nav_organize"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:background="@drawable/bg_bottom_nav_item"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="?attr/selectableItemBackgroundBorderless"
                    android:gravity="center"
                    android:minWidth="@dimen/bottom_nav_item_min_width"
                    android:minHeight="@dimen/bottom_nav_item_min_height"
                    android:orientation="vertical"
                    android:paddingStart="@dimen/bottom_nav_item_padding_horizontal"
                    android:paddingTop="@dimen/bottom_nav_item_padding_vertical"
                    android:paddingEnd="@dimen/bottom_nav_item_padding_horizontal"
                    android:paddingBottom="@dimen/bottom_nav_item_padding_vertical">

                    <ImageView
                        android:layout_width="@dimen/bottom_nav_icon_size"
                        android:layout_height="@dimen/bottom_nav_icon_size"
                        android:duplicateParentState="true"
                        android:src="@drawable/ic_organize"
                        android:tint="@color/nav_item_color" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="3dp"
                        android:duplicateParentState="true"
                        android:text="Organize"
                        android:textAppearance="@style/TextAppearance.Breezeseas.BottomNavigation"
                        android:textColor="@color/nav_item_color" />
                </LinearLayout>
            </FrameLayout>

            <FrameLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1">

                <LinearLayout
                    android:id="@+id/nav_notification"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:background="@drawable/bg_bottom_nav_item"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="?attr/selectableItemBackgroundBorderless"
                    android:gravity="center"
                    android:minWidth="@dimen/bottom_nav_item_min_width"
                    android:minHeight="@dimen/bottom_nav_item_min_height"
                    android:orientation="vertical"
                    android:paddingStart="@dimen/bottom_nav_item_padding_horizontal"
                    android:paddingTop="@dimen/bottom_nav_item_padding_vertical"
                    android:paddingEnd="@dimen/bottom_nav_item_padding_horizontal"
                    android:paddingBottom="@dimen/bottom_nav_item_padding_vertical">

                    <ImageView
                        android:layout_width="@dimen/bottom_nav_icon_size"
                        android:layout_height="@dimen/bottom_nav_icon_size"
                        android:duplicateParentState="true"
                        android:src="@drawable/ic_notification"
                        android:tint="@color/nav_item_color" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="3dp"
                        android:duplicateParentState="true"
                        android:text="Alerts"
                        android:textAppearance="@style/TextAppearance.Breezeseas.BottomNavigation"
                        android:textColor="@color/nav_item_color" />
                </LinearLayout>
            </FrameLayout>

            <FrameLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1">

                <LinearLayout
                    android:id="@+id/nav_profile"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:background="@drawable/bg_bottom_nav_item"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="?attr/selectableItemBackgroundBorderless"
                    android:gravity="center"
                    android:minWidth="@dimen/bottom_nav_item_min_width"
                    android:minHeight="@dimen/bottom_nav_item_min_height"
                    android:orientation="vertical"
                    android:paddingStart="@dimen/bottom_nav_item_padding_horizontal"
                    android:paddingTop="@dimen/bottom_nav_item_padding_vertical"
                    android:paddingEnd="@dimen/bottom_nav_item_padding_horizontal"
                    android:paddingBottom="@dimen/bottom_nav_item_padding_vertical">

                    <ImageView
                        android:layout_width="@dimen/bottom_nav_icon_size"
                        android:layout_height="@dimen/bottom_nav_icon_size"
                        android:duplicateParentState="true"
                        android:src="@drawable/ic_profile"
                        android:tint="@color/nav_item_color" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="3dp"
                        android:duplicateParentState="true"
                        android:text="Profile"
                        android:textAppearance="@style/TextAppearance.Breezeseas.BottomNavigation"
                        android:textColor="@color/nav_item_color" />
                </LinearLayout>
            </FrameLayout>
        </LinearLayout>
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
