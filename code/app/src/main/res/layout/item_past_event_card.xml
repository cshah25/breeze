<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="16dp"
    android:layout_marginVertical="8dp"
    android:background="@drawable/bg_welcome_hero_shell"
    android:clickable="true"
    android:elevation="10dp"
    android:focusable="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:minHeight="170dp"
        android:orientation="vertical"
        android:padding="18dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:baselineAligned="false"
            android:gravity="top|center_vertical"
            android:orientation="horizontal">

            <FrameLayout
                android:id="@+id/past_event_icon_surface"
                android:layout_width="46dp"
                android:layout_height="46dp"
                android:background="@drawable/bg_ticket_qr_placeholder">

                <ImageView
                    android:id="@+id/past_event_icon"
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:layout_gravity="center"
                    android:contentDescription="Past event icon"
                    android:src="@drawable/ic_ticket" />
            </FrameLayout>

            <Space
                android:layout_width="12dp"
                android:layout_height="1dp" />

            <TextView
                android:id="@+id/past_event_status_chip"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_ticket_status_outline"
                android:fontFamily="@font/inter_medium"
                android:paddingStart="12dp"
                android:paddingTop="8dp"
                android:paddingEnd="12dp"
                android:paddingBottom="8dp"
                android:text="Attended"
                android:textColor="@color/text_primary"
                android:textSize="11sp" />
        </LinearLayout>

        <TextView
            android:id="@+id/past_event_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:fontFamily="@font/inter_semibold"
            android:maxLines="2"
            android:text="Beginner Swimming Lessons"
            android:textColor="@color/text_primary"
            android:textSize="17sp" />

        <TextView
            android:id="@+id/past_event_date"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:fontFamily="@font/inter_regular"
            android:text="Wed, Jan 15 • 5:30 PM"
            android:textColor="@color/text_secondary"
            android:textSize="13sp" />

        <TextView
            android:id="@+id/past_event_location"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:fontFamily="@font/inter_regular"
            android:text="Kinsmen Sports Centre"
            android:textColor="@color/text_primary"
            android:textSize="13sp" />

        <TextView
            android:id="@+id/past_event_detail"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:fontFamily="@font/inter_medium"
            android:text="Completed successfully"
            android:textColor="@color/text_secondary"
            android:textSize="12sp" />

    </LinearLayout>

</FrameLayout>
