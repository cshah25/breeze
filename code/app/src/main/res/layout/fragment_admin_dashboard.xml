<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/colorSurface">

    <com.google.android.material.appbar.AppBarLayout
        android:id="@+id/ad_appBarLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/ad_topAppBar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            app:title="Admin Dashboard"
            app:navigationIcon="@android:drawable/ic_menu_revert"
            app:navigationContentDescription="Go back" />
    </com.google.android.material.appbar.AppBarLayout>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/ad_btn_view_events"
        android:layout_width="0dp"
        android:layout_height="64dp"
        android:text="View All Events"
        android:layout_marginHorizontal="16dp"
        android:layout_marginTop="48dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/ad_appBarLayout" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/ad_btn_view_profiles"
        android:layout_width="0dp"
        android:layout_height="64dp"
        android:text="View User Profiles"
        android:layout_marginHorizontal="16dp"
        android:layout_marginTop="16dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/ad_btn_view_events" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/ad_btn_view_images"
        android:layout_width="0dp"
        android:layout_height="64dp"
        android:text="View All Images"
        android:layout_marginHorizontal="16dp"
        android:layout_marginTop="16dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/ad_btn_view_profiles" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/ad_btn_view_logs"
        android:layout_width="0dp"
        android:layout_height="64dp"
        android:text="View Logs"
        android:layout_marginHorizontal="16dp"
        android:layout_marginTop="16dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/ad_btn_view_images" />

</androidx.constraintlayout.widget.ConstraintLayout>