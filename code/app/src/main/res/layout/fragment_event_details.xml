<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/event_details_wrapper"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white"
    android:clipToPadding="false"
    android:fillViewport="true"
    android:paddingStart="20dp"
    android:paddingTop="20dp"
    android:paddingEnd="20dp"
    android:paddingBottom="32dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <ImageView
                android:id="@+id/event_details_return_button"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="@drawable/bg_profile_field_shell"
                android:contentDescription="@string/organizer_back"
                android:padding="8dp"
                android:src="@drawable/ic_go_back" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:fontFamily="@font/inter_medium"
                android:text="Event Details"
                android:textColor="@color/text_secondary"
                android:textSize="14sp" />
        </LinearLayout>

        <TextView
            android:id="@+id/event_details_event_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="22dp"
            android:fontFamily="@font/inter_semibold"
            android:text="Event Name"
            android:textColor="@color/text_primary"
            android:textSize="30sp" />

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="250dp"
            android:layout_marginTop="18dp"
            android:background="@drawable/bg_welcome_hero_shell"
            android:elevation="10dp"
            android:padding="12dp">

            <ImageView
                android:id="@+id/event_details_event_photo"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@drawable/bg_profile_field_shell"
                android:contentDescription="@string/organizer_event_preview_poster"
                android:padding="12dp"
                android:scaleType="centerCrop"
                android:src="@drawable/ic_image_placeholder" />
        </FrameLayout>

        <Button
            android:id="@+id/event_details_view_QRCode_button"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="16dp"
            android:background="@drawable/bg_ticket_status_outline"
            android:backgroundTint="@null"
            android:fontFamily="@font/inter_medium"
            android:text="View QR Code"
            android:textAllCaps="false"
            android:textColor="@color/text_primary"
            android:textSize="14sp"
            app:backgroundTint="@null" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:orientation="horizontal">

            <FrameLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginEnd="8dp"
                android:layout_weight="1"
                android:background="@drawable/bg_profile_field_shell"
                android:padding="16dp">

                <TextView
                    android:id="@+id/event_details_event_capacity"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/inter_medium"
                    android:textColor="@color/text_primary"
                    android:textSize="14sp" />
            </FrameLayout>

            <FrameLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:background="@drawable/bg_profile_field_shell"
                android:padding="16dp">

                <TextView
                    android:id="@+id/event_details_event_waiting_list_count"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/inter_medium"
                    android:textColor="@color/text_primary"
                    android:textSize="14sp" />
            </FrameLayout>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:orientation="horizontal">

            <FrameLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginEnd="8dp"
                android:layout_weight="1"
                android:background="@drawable/bg_profile_field_shell"
                android:padding="16dp">

                <TextView
                    android:id="@+id/event_details_event_start_date"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/inter_medium"
                    android:textColor="@color/text_primary"
                    android:textSize="14sp" />
            </FrameLayout>

            <FrameLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:background="@drawable/bg_profile_field_shell"
                android:padding="16dp">

                <TextView
                    android:id="@+id/event_details_event_end_date"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/inter_medium"
                    android:textColor="@color/text_primary"
                    android:textSize="14sp" />
            </FrameLayout>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:background="@drawable/bg_profile_panel_shell"
            android:orientation="vertical"
            android:padding="18dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:fontFamily="@font/inter_medium"
                android:text="About this event"
                android:textColor="@color/text_primary"
                android:textSize="13sp" />

            <TextView
                android:id="@+id/event_details_event_description"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:fontFamily="@font/inter_regular"
                android:lineSpacingExtra="2dp"
                android:text="Insert Event Description Here"
                android:textColor="@color/text_secondary"
                android:textSize="15sp" />
        </LinearLayout>

        <TextView
            android:id="@+id/event_details_invite_text"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:fontFamily="@font/inter_medium"
            android:gravity="center"
            android:text="You got invited!"
            android:textColor="@color/text_primary"
            android:textSize="16sp"
            android:visibility="gone" />

        <LinearLayout
            android:id="@+id/event_details_action_row"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:orientation="vertical">

            <Button
                android:id="@+id/event_details_join_waitlist_button"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:background="@drawable/bg_welcome_primary_button"
                android:backgroundTint="@null"
                android:fontFamily="@font/inter_medium"
                android:text="Join Waiting List"
                android:textAllCaps="false"
                android:textColor="@color/white"
                android:textSize="14sp"
                android:visibility="gone"
                app:backgroundTint="@null" />

            <Button
                android:id="@+id/event_details_leave_waitlist_button"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:background="@drawable/bg_ticket_status_outline"
                android:backgroundTint="@null"
                android:fontFamily="@font/inter_medium"
                android:text="Leave Waiting List"
                android:textAllCaps="false"
                android:textColor="@color/text_primary"
                android:textSize="14sp"
                android:visibility="gone"
                app:backgroundTint="@null" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <Button
                    android:id="@+id/event_details_accept_invite_button"
                    android:layout_width="0dp"
                    android:layout_height="52dp"
                    android:layout_marginEnd="6dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_welcome_primary_button"
                    android:backgroundTint="@null"
                    android:fontFamily="@font/inter_medium"
                    android:text="Accept"
                    android:textAllCaps="false"
                    android:textColor="@color/white"
                    android:textSize="14sp"
                    android:visibility="gone"
                    app:backgroundTint="@null" />

                <Button
                    android:id="@+id/event_details_decline_invite_button"
                    android:layout_width="0dp"
                    android:layout_height="52dp"
                    android:layout_marginStart="6dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_ticket_status_outline"
                    android:backgroundTint="@null"
                    android:fontFamily="@font/inter_medium"
                    android:text="Decline"
                    android:textAllCaps="false"
                    android:textColor="@color/text_primary"
                    android:textSize="14sp"
                    android:visibility="gone"
                    app:backgroundTint="@null" />
            </LinearLayout>
        </LinearLayout>

        <TextView
            android:id="@+id/event_details_invite_accepted_text"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:background="@drawable/bg_profile_field_shell"
            android:fontFamily="@font/inter_semibold"
            android:gravity="center"
            android:padding="18dp"
            android:text="Hooray!&#10;You're in the event!"
            android:textColor="@color/text_primary"
            android:textSize="20sp"
            android:visibility="gone" />

        <TextView
            android:id="@+id/event_details_invite_declined_text"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:background="@drawable/bg_profile_field_shell"
            android:fontFamily="@font/inter_semibold"
            android:gravity="center"
            android:padding="18dp"
            android:text="Invitation Declined.&#10;Maybe next time."
            android:textColor="@color/text_primary"
            android:textSize="20sp"
            android:visibility="gone" />

    </LinearLayout>

</androidx.core.widget.NestedScrollView>
