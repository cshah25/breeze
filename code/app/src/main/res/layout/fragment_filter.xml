<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/surface_subtle"
    android:fillViewport="true"
    android:paddingStart="@dimen/screen_horizontal_padding"
    android:paddingTop="@dimen/screen_vertical_padding"
    android:paddingEnd="@dimen/screen_horizontal_padding"
    android:paddingBottom="@dimen/screen_bottom_padding">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <ImageButton
                android:id="@+id/filter_back_button"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="@drawable/bg_profile_field_shell"
                android:contentDescription="@string/filter_back"
                android:padding="8dp"
                android:src="@drawable/ic_go_back" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:fontFamily="@font/inter_medium"
                android:text="@string/filter_header"
                android:textColor="@color/text_secondary"
                android:textSize="14sp" />
        </LinearLayout>

        <TextView
            android:id="@+id/filter_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:text="@string/filter_title"
            android:textAppearance="@style/TextAppearance.Breezeseas.ScreenTitle"
            android:textSize="28sp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:background="@drawable/bg_welcome_hero_shell"
            android:orientation="vertical"
            android:padding="@dimen/surface_padding">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/filter_availability_label"
                android:textAppearance="@style/TextAppearance.Breezeseas.SectionLabel" />

            <TextView
                android:id="@+id/filter_availability_summary"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="@string/filter_availability_summary_any"
                android:textAppearance="@style/TextAppearance.Breezeseas.ScreenSubtitle" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/filter_availability_button"
                style="@style/Widget.Breezeseas.Button.Secondary"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="@string/filter_select_dates" />

            <TextView
                android:id="@+id/filter_clear_dates_button"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="end"
                android:layout_marginTop="12dp"
                android:fontFamily="@font/inter_medium"
                android:text="@string/filter_clear_dates"
                android:textColor="@color/text_secondary"
                android:textSize="13sp"
                android:visibility="gone" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:orientation="horizontal">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:background="@drawable/bg_profile_field_shell"
                    android:orientation="vertical"
                    android:padding="14dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/filter_available_from"
                        android:textAppearance="@style/TextAppearance.Breezeseas.SurfaceChip" />

                    <TextView
                        android:id="@+id/filter_start_value"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:fontFamily="@font/inter_medium"
                        android:text="@string/filter_any_date"
                        android:textColor="@color/text_primary"
                        android:textSize="15sp" />
                </LinearLayout>

                <Space
                    android:layout_width="12dp"
                    android:layout_height="1dp" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:background="@drawable/bg_profile_field_shell"
                    android:orientation="vertical"
                    android:padding="14dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/filter_available_to"
                        android:textAppearance="@style/TextAppearance.Breezeseas.SurfaceChip" />

                    <TextView
                        android:id="@+id/filter_end_value"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:fontFamily="@font/inter_medium"
                        android:text="@string/filter_any_date"
                        android:textColor="@color/text_primary"
                        android:textSize="15sp" />
                </LinearLayout>
            </LinearLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="28dp"
                android:text="@string/filter_capacity_label"
                android:textAppearance="@style/TextAppearance.Breezeseas.SectionLabel" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="@string/filter_capacity_support"
                android:textAppearance="@style/TextAppearance.Breezeseas.ScreenSubtitle" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:orientation="horizontal">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:background="@drawable/bg_profile_field_shell"
                    android:orientation="vertical"
                    android:paddingStart="14dp"
                    android:paddingTop="12dp"
                    android:paddingEnd="14dp"
                    android:paddingBottom="12dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/filter_min_capacity_hint"
                        android:textAppearance="@style/TextAppearance.Breezeseas.SurfaceChip" />

                    <EditText
                        android:id="@+id/filter_min_capacity_input"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:background="@null"
                        android:fontFamily="@font/inter_regular"
                        android:hint="@string/filter_capacity_example_min"
                        android:imeOptions="actionNext"
                        android:inputType="number"
                        android:maxLines="1"
                        android:padding="0dp"
                        android:textColor="@color/text_primary"
                        android:textColorHint="@color/text_secondary"
                        android:textSize="16sp" />
                </LinearLayout>

                <Space
                    android:layout_width="12dp"
                    android:layout_height="1dp" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:background="@drawable/bg_profile_field_shell"
                    android:orientation="vertical"
                    android:paddingStart="14dp"
                    android:paddingTop="12dp"
                    android:paddingEnd="14dp"
                    android:paddingBottom="12dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/filter_max_capacity_hint"
                        android:textAppearance="@style/TextAppearance.Breezeseas.SurfaceChip" />

                    <EditText
                        android:id="@+id/filter_max_capacity_input"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:background="@null"
                        android:fontFamily="@font/inter_regular"
                        android:hint="@string/filter_capacity_example_max"
                        android:imeOptions="actionDone"
                        android:inputType="number"
                        android:maxLines="1"
                        android:padding="0dp"
                        android:textColor="@color/text_primary"
                        android:textColorHint="@color/text_secondary"
                        android:textSize="16sp" />
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/filter_clear_all_button"
                style="@style/Widget.Breezeseas.Button.Secondary"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/filter_clear_all" />

            <Space
                android:layout_width="12dp"
                android:layout_height="1dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/filter_apply_button"
                style="@style/Widget.Breezeseas.Button.Primary"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/filter_apply" />
        </LinearLayout>
    </LinearLayout>
</androidx.core.widget.NestedScrollView>
