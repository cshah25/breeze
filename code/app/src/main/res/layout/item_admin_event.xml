<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="16dp"
    android:background="@drawable/bg_welcome_hero_shell"
    android:clickable="true"
    android:elevation="8dp"
    android:focusable="true"
    android:orientation="vertical"
    android:padding="18dp">

    <FrameLayout
        android:id="@+id/iae_iv_image_frame"
        android:layout_width="match_parent"
        android:layout_height="176dp"
        android:background="@drawable/bg_profile_field_shell">

        <com.google.android.material.imageview.ShapeableImageView
            android:id="@+id/iae_iv_event_poster"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:contentDescription="@string/organizer_event_preview_poster"
            android:scaleType="centerCrop"
            android:src="@drawable/ic_image_placeholder"
            app:shapeAppearanceOverlay="@style/RoundedCorners.ExploreEventEntry" />
    </FrameLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/iae_tv_event_title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:fontFamily="@font/inter_semibold"
            android:text="Event Name"
            android:textColor="@color/text_primary"
            android:textSize="22sp" />

        <ImageView
            android:id="@+id/iae_btn_delete_event"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:clickable="true"
            android:focusable="true"
            android:padding="8dp"
            android:src="@android:drawable/ic_menu_delete"
            app:tint="?attr/colorError" />
    </LinearLayout>

    <TextView
        android:id="@+id/iae_tv_event_details"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:ellipsize="end"
        android:fontFamily="@font/inter_regular"
        android:lineSpacingExtra="2dp"
        android:maxLines="3"
        android:text="Event description preview"
        android:textColor="@color/text_secondary"
        android:textSize="15sp" />

    <TextView
        android:id="@+id/iae_tv_event_dates"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:background="@drawable/bg_profile_field_shell"
        android:fontFamily="@font/inter_medium"
        android:paddingStart="14dp"
        android:paddingTop="13dp"
        android:paddingEnd="14dp"
        android:paddingBottom="13dp"
        android:text="Registration closes Mar 19, 2026"
        android:textColor="@color/text_primary"
        android:textSize="14sp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/iae_tv_event_waiting_list"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginEnd="8dp"
            android:layout_weight="1"
            android:background="@drawable/bg_ticket_status_outline"
            android:fontFamily="@font/inter_medium"
            android:gravity="center"
            android:paddingStart="12dp"
            android:paddingTop="10dp"
            android:paddingEnd="12dp"
            android:paddingBottom="10dp"
            android:text="Lottery entry"
            android:textColor="@color/text_primary"
            android:textSize="13sp" />

        <TextView
            android:id="@+id/iae_tv_event_capacity"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginEnd="8dp"
            android:layout_weight="1"
            android:background="@drawable/bg_ticket_status_outline"
            android:fontFamily="@font/inter_medium"
            android:gravity="center"
            android:paddingStart="12dp"
            android:paddingTop="10dp"
            android:paddingEnd="12dp"
            android:paddingBottom="10dp"
            android:text="Unlimited waitlist"
            android:textColor="@color/text_primary"
            android:textSize="13sp" />

        <TextView
            android:id="@+id/iae_tv_event_geo"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:background="@drawable/bg_ticket_status_outline"
            android:fontFamily="@font/inter_medium"
            android:gravity="center"
            android:paddingStart="12dp"
            android:paddingTop="10dp"
            android:paddingEnd="12dp"
            android:paddingBottom="10dp"
            android:text="Geo optional"
            android:textColor="@color/text_primary"
            android:textSize="13sp" />
    </LinearLayout>

</LinearLayout>
