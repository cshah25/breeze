<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/colorSurface">

    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/aed_toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            app:navigationIcon="@android:drawable/ic_menu_revert"
            app:title="Event Details" />

    </com.google.android.material.appbar.AppBarLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="16dp"
            android:paddingBottom="32dp">

            <!-- Poster -->
            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="220dp"
                android:layout_marginTop="16dp"
                android:background="@drawable/bg_profile_field_shell"
                android:clipChildren="true"
                android:clipToPadding="true">

                <com.google.android.material.imageview.ShapeableImageView
                    android:id="@+id/aed_iv_poster"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:scaleType="centerCrop"
                    app:shapeAppearance="@style/RoundedCorners.ExploreEventEntry" />

            </FrameLayout>

            <!-- Event name -->
            <TextView
                android:id="@+id/aed_tv_name"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:fontFamily="@font/inter_semibold"
                android:textColor="@color/text_primary"
                android:textSize="22sp" />

            <!-- Description -->
            <TextView
                android:id="@+id/aed_tv_description"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:fontFamily="@font/inter_regular"
                android:textColor="@color/text_secondary"
                android:textSize="15sp" />

            <!-- Info pills -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/aed_tv_capacity"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="8dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_profile_field_shell"
                    android:fontFamily="@font/inter_medium"
                    android:paddingHorizontal="12dp"
                    android:paddingVertical="8dp"
                    android:textColor="@color/text_primary"
                    android:textSize="13sp" />

                <TextView
                    android:id="@+id/aed_tv_waiting_list"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:background="@drawable/bg_profile_field_shell"
                    android:fontFamily="@font/inter_medium"
                    android:paddingHorizontal="12dp"
                    android:paddingVertical="8dp"
                    android:textColor="@color/text_primary"
                    android:textSize="13sp" />

            </LinearLayout>

            <!-- Registration closes -->
            <TextView
                android:id="@+id/aed_tv_reg_closes"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:background="@drawable/bg_profile_field_shell"
                android:fontFamily="@font/inter_medium"
                android:paddingHorizontal="12dp"
                android:paddingVertical="8dp"
                android:textColor="@color/text_primary"
                android:textSize="13sp" />

            <!-- Organizer -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:fontFamily="@font/inter_semibold"
                android:text="Organizer"
                android:textColor="@color/text_primary"
                android:textSize="16sp" />

            <TextView
                android:id="@+id/aed_tv_organizer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:background="@drawable/bg_profile_field_shell"
                android:fontFamily="@font/inter_regular"
                android:paddingHorizontal="12dp"
                android:paddingVertical="10dp"
                android:textColor="@color/text_primary"
                android:textSize="14sp" />

            <!-- Co-organizers (hidden when empty) -->
            <TextView
                android:id="@+id/aed_tv_coorganizers_label"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:fontFamily="@font/inter_semibold"
                android:text="Co-organizers"
                android:textColor="@color/text_primary"
                android:textSize="16sp"
                android:visibility="gone" />

            <TextView
                android:id="@+id/aed_tv_coorganizers"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:background="@drawable/bg_profile_field_shell"
                android:fontFamily="@font/inter_regular"
                android:paddingHorizontal="12dp"
                android:paddingVertical="10dp"
                android:textColor="@color/text_primary"
                android:textSize="14sp"
                android:visibility="gone" />

            <!-- Comments -->
            <include layout="@layout/include_event_comments_section" />

        </LinearLayout>

    </androidx.core.widget.NestedScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
