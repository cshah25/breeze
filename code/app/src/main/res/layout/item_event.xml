<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_marginBottom="14dp"
    android:background="@drawable/bg_welcome_hero_shell"
    android:clickable="true"
    android:elevation="8dp"
    android:focusable="true"
    android:orientation="vertical"
    android:padding="20dp">

    <FrameLayout
        android:id="@+id/ivEventPosterFrame"
        android:layout_width="match_parent"
        android:layout_height="160dp"
        android:background="@drawable/bg_profile_field_shell"
        android:padding="0dp">

        <com.google.android.material.imageview.ShapeableImageView
            android:id="@+id/ivEventPoster"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:contentDescription="@string/organizer_event_preview_poster"
            android:scaleType="centerCrop"
            android:src="@drawable/ic_image_placeholder"
            app:shapeAppearanceOverlay="@style/RoundedCorners.OrganizeEventEntry" />

    </FrameLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:baselineAligned="false"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/tvEventName"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:ellipsize="end"
            android:maxLines="2"
            android:textAppearance="@style/TextAppearance.Breezeseas.CardTitle"
            android:text="Event Name"
            android:textSize="20sp" />

        <TextView
            android:id="@+id/tvEventTypeChip"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:background="@drawable/bg_ticket_status_outline"
            android:gravity="center"
            android:minHeight="30dp"
            android:minWidth="68dp"
            android:paddingStart="11dp"
            android:paddingTop="6dp"
            android:paddingEnd="11dp"
            android:paddingBottom="6dp"
            android:textAppearance="@style/TextAppearance.Breezeseas.SurfaceChip"
            android:text="@string/organize_event_type_public"
            android:textSize="11sp" />

    </LinearLayout>

    <TextView
        android:id="@+id/tvEventDates"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:fontFamily="@font/inter_regular"
        android:text="Reg: Mar 1 → Mar 5"
        android:textColor="@color/text_secondary"
        android:textSize="14sp" />

    <TextView
        android:id="@+id/tvEventCapacity"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:fontFamily="@font/inter_regular"
        android:text="Waiting list cap: Unlimited"
        android:textColor="@color/text_secondary"
        android:textSize="14sp" />

    <TextView
        android:id="@+id/tvEventDetails"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:ellipsize="end"
        android:fontFamily="@font/inter_regular"
        android:maxLines="2"
        android:text="Event details preview"
        android:textColor="@color/text_primary"
        android:textSize="15sp" />

    <TextView
        android:id="@+id/tvEventAction"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="14dp"
        android:background="@drawable/bg_profile_field_shell"
        android:fontFamily="@font/inter_medium"
        android:paddingStart="12dp"
        android:paddingTop="7dp"
        android:paddingEnd="12dp"
        android:paddingBottom="7dp"
        android:text="Open Preview"
        android:textColor="@color/text_primary"
        android:textSize="12sp"
        android:visibility="gone" />
</LinearLayout>
