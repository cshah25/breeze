<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/surface_subtle">

    <View
        android:layout_width="220dp"
        android:layout_height="220dp"
        android:alpha="0.76"
        android:background="@drawable/bg_breeze_orb"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <View
        android:layout_width="180dp"
        android:layout_height="180dp"
        android:alpha="0.46"
        android:background="@drawable/bg_breeze_orb"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <LinearLayout
        android:id="@+id/welcome_content"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="28dp"
        android:layout_marginEnd="28dp"
        android:gravity="center_horizontal"
        android:orientation="vertical"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_bias="0.44">

        <FrameLayout
            android:layout_width="148dp"
            android:layout_height="148dp"
            android:background="@drawable/bg_welcome_hero_shell"
            android:elevation="12dp"
            android:padding="24dp">

            <ImageView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:adjustViewBounds="true"
                android:contentDescription="@string/welcome_illustration_desc"
                android:scaleType="centerInside"
                android:src="@mipmap/ic_launcher_round" />
        </FrameLayout>

        <TextView
            android:id="@+id/welcome_app_name"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="28dp"
            android:fontFamily="@font/inter_bold"
            android:text="@string/welcome_brand"
            android:textColor="@color/text_primary"
            android:textSize="34sp" />

        <TextView
            android:id="@+id/welcome_subtitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:fontFamily="@font/inter_regular"
            android:gravity="center"
            android:lineSpacingExtra="2dp"
            android:text="@string/welcome_subtitle"
            android:textColor="@color/text_secondary"
            android:textSize="15sp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/welcome_screen_start_button"
            style="@style/Widget.Breezeseas.Button.Base"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="30dp"
            android:background="@drawable/bg_welcome_primary_button"
            android:text="@string/get_started"
            android:textColor="@android:color/white"
            android:textSize="16sp"
            app:backgroundTint="@null" />
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
