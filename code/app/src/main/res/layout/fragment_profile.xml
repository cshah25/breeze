<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/surface_subtle"
    android:clipToPadding="false"
    android:fillViewport="true"
    android:paddingStart="20dp"
    android:paddingTop="20dp"
    android:paddingEnd="20dp"
    android:paddingBottom="120dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <TextView
            android:id="@+id/profile_section_label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/profile_account_label"
            android:textAppearance="@style/TextAppearance.Breezeseas.SectionLabel" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:background="@drawable/bg_profile_panel_shell"
            android:orientation="vertical">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:foregroundGravity="center">

                    <FrameLayout
                        android:layout_width="136dp"
                        android:layout_height="136dp"
                        android:layout_gravity="center"
                        android:background="@drawable/bg_soft_surface"
                        android:padding="8dp">

                        <com.google.android.material.imageview.ShapeableImageView
                            android:id="@+id/profile_image"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:contentDescription="@string/profile_photo_content_description"
                            android:scaleType="centerCrop"
                            android:src="@drawable/ic_profile"
                            app:shapeAppearanceOverlay="@style/CircleImage" />
                    </FrameLayout>
                </FrameLayout>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/choose_profile_photo_button"
                    style="@style/Widget.Breezeseas.Button.Secondary"
                    android:layout_width="wrap_content"
                    android:layout_height="@dimen/button_small_height"
                    android:layout_gravity="center_horizontal"
                    android:layout_marginTop="14dp"
                    android:text="@string/profile_choose_photo" />

                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="24dp"
                    android:background="@drawable/bg_profile_field_shell"
                    android:paddingStart="14dp"
                    android:paddingTop="6dp"
                    android:paddingEnd="14dp"
                    android:paddingBottom="2dp"
                    android:foregroundGravity="center_vertical">

                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/first_name_filled_text_field"
                        style="@style/Widget.Breezeseas.ProfileTextInput"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginEnd="42dp"
                        android:enabled="false"
                        android:hint="@string/first_name">

                        <com.google.android.material.textfield.TextInputEditText
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:background="@null"
                            android:padding="0dp"
                            android:textColor="@color/text_primary"
                            android:textColorHint="@color/text_secondary" />

                    </com.google.android.material.textfield.TextInputLayout>

                    <ImageButton
                        android:id="@+id/edit_first_name_button"
                        android:layout_width="28dp"
                        android:layout_height="28dp"
                        android:layout_gravity="end|center_vertical"
                        android:layout_marginEnd="10dp"
                        android:background="@null"
                        android:contentDescription="@string/edits_first_name"
                        android:padding="4dp"
                        android:src="@drawable/ic_edit"
                        app:tint="@color/text_secondary" />
                </FrameLayout>

                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:background="@drawable/bg_profile_field_shell"
                    android:paddingStart="14dp"
                    android:paddingTop="6dp"
                    android:paddingEnd="14dp"
                    android:paddingBottom="2dp"
                    android:foregroundGravity="center_vertical">

                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/last_name_filled_text_field"
                        style="@style/Widget.Breezeseas.ProfileTextInput"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginEnd="42dp"
                        android:enabled="false"
                        android:hint="@string/last_name">

                        <com.google.android.material.textfield.TextInputEditText
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:background="@null"
                            android:padding="0dp"
                            android:textColor="@color/text_primary"
                            android:textColorHint="@color/text_secondary" />

                    </com.google.android.material.textfield.TextInputLayout>

                    <ImageButton
                        android:id="@+id/edit_last_name_button"
                        android:layout_width="28dp"
                        android:layout_height="28dp"
                        android:layout_gravity="end|center_vertical"
                        android:layout_marginEnd="10dp"
                        android:background="@null"
                        android:contentDescription="@string/edits_name"
                        android:padding="4dp"
                        android:src="@drawable/ic_edit"
                        app:tint="@color/text_secondary" />
                </FrameLayout>

                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:background="@drawable/bg_profile_field_shell"
                    android:paddingStart="14dp"
                    android:paddingTop="6dp"
                    android:paddingEnd="14dp"
                    android:paddingBottom="2dp"
                    android:foregroundGravity="center_vertical">

                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/user_name_filled_text_field"
                        style="@style/Widget.Breezeseas.ProfileTextInput"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginEnd="42dp"
                        android:enabled="false"
                        android:hint="@string/user_name">

                        <com.google.android.material.textfield.TextInputEditText
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:background="@null"
                            android:padding="0dp"
                            android:textColor="@color/text_primary"
                            android:textColorHint="@color/text_secondary" />

                    </com.google.android.material.textfield.TextInputLayout>

                    <ImageButton
                        android:id="@+id/edit_user_name_button"
                        android:layout_width="28dp"
                        android:layout_height="28dp"
                        android:layout_gravity="end|center_vertical"
                        android:layout_marginEnd="10dp"
                        android:background="@null"
                        android:contentDescription="@string/edits_user_name"
                        android:padding="4dp"
                        android:src="@drawable/ic_edit"
                        app:tint="@color/text_secondary" />
                </FrameLayout>

                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:background="@drawable/bg_profile_field_shell"
                    android:paddingStart="14dp"
                    android:paddingTop="6dp"
                    android:paddingEnd="14dp"
                    android:paddingBottom="2dp"
                    android:foregroundGravity="center_vertical">

                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/email_filled_text_field"
                        style="@style/Widget.Breezeseas.ProfileTextInput"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginEnd="42dp"
                        android:enabled="false"
                        android:hint="@string/email">

                        <com.google.android.material.textfield.TextInputEditText
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:background="@null"
                            android:padding="0dp"
                            android:textColor="@color/text_primary"
                            android:textColorHint="@color/text_secondary" />

                    </com.google.android.material.textfield.TextInputLayout>

                    <ImageButton
                        android:id="@+id/edit_email_button"
                        android:layout_width="28dp"
                        android:layout_height="28dp"
                        android:layout_gravity="end|center_vertical"
                        android:layout_marginEnd="10dp"
                        android:background="@null"
                        android:contentDescription="@string/edits_email"
                        android:padding="4dp"
                        android:src="@drawable/ic_edit"
                        app:tint="@color/text_secondary" />
                </FrameLayout>

                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:background="@drawable/bg_profile_field_shell"
                    android:paddingStart="14dp"
                    android:paddingTop="6dp"
                    android:paddingEnd="14dp"
                    android:paddingBottom="2dp"
                    android:foregroundGravity="center_vertical">

                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/phone_number_filled_text_field"
                        style="@style/Widget.Breezeseas.ProfileTextInput"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginEnd="42dp"
                        android:enabled="false"
                        android:hint="@string/phone_number">

                        <com.google.android.material.textfield.TextInputEditText
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:background="@null"
                            android:padding="0dp"
                            android:textColor="@color/text_primary"
                            android:textColorHint="@color/text_secondary" />

                    </com.google.android.material.textfield.TextInputLayout>

                    <ImageButton
                        android:id="@+id/edit_phone_number_button"
                        android:layout_width="28dp"
                        android:layout_height="28dp"
                        android:layout_gravity="end|center_vertical"
                        android:layout_marginEnd="10dp"
                        android:background="@null"
                        android:contentDescription="@string/edits_name"
                        android:padding="4dp"
                        android:src="@drawable/ic_edit"
                        app:tint="@color/text_secondary" />
                </FrameLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="20dp"
                    android:background="@drawable/bg_profile_field_shell"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingStart="16dp"
                    android:paddingTop="14dp"
                    android:paddingEnd="16dp"
                    android:paddingBottom="14dp">

                    <com.google.android.material.textview.MaterialTextView
                        android:id="@+id/opt_out_text"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:fontFamily="@font/inter_medium"
                        android:text="@string/opt_out"
                        android:textColor="@color/text_primary"
                        android:textSize="14sp" />

                    <com.google.android.material.materialswitch.MaterialSwitch
                        android:id="@+id/opt_out_switch"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        app:thumbTint="@color/profile_switch_thumb_color"
                        app:trackTint="@color/profile_switch_track_color" />
                </LinearLayout>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/save_button"
                    style="@style/Widget.Breezeseas.Button.Primary"
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/button_height"
                    android:layout_marginTop="20dp"
                    android:text="@string/save" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/delete_profile_button"
                    style="@style/Widget.Breezeseas.Button.Destructive"
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/button_height"
                    android:layout_marginTop="12dp"
                    android:text="Delete Profile" />

            </LinearLayout>
        </LinearLayout>

    </LinearLayout>
</androidx.core.widget.NestedScrollView>
