<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:paddingStart="20dp"
    android:paddingEnd="20dp"
    android:paddingTop="20dp"
    android:paddingBottom="20dp">

    <TextView
        android:id="@+id/backup_sheet_title"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="You're on the Waitlist"
        android:textColor="@color/black"
        android:textSize="28sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/backup_sheet_body"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="14dp"
        android:text="The first draw is complete. You are currently in the backup pool. If any tickets are declined, we will run another draw and notify you."
        android:textColor="#6B7280"
        android:textSize="18sp"
        android:lineSpacingExtra="6dp" />

    <Button
        android:id="@+id/backup_sheet_ok"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="end"
        android:layout_marginTop="22dp"
        android:backgroundTint="@color/black"
        android:text="Okay" />
</LinearLayout>