<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/surface_subtle"
    android:clipToPadding="false"
    android:fillViewport="true"
    android:paddingStart="20dp"
    android:paddingTop="20dp"
    android:paddingEnd="20dp"
    android:paddingBottom="32dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <ImageButton
                android:id="@+id/organizer_event_preview_back"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="@drawable/bg_profile_field_shell"
                android:contentDescription="@string/organizer_back"
                android:padding="8dp"
                android:src="@drawable/ic_go_back" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:fontFamily="@font/inter_medium"
                android:text="@string/organizer_event_preview_header"
                android:textColor="@color/text_secondary"
                android:textSize="14sp" />

            <View
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:layout_weight="1" />

            <ImageButton
                android:id="@+id/organizer_event_preview_menu_button"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="@drawable/bg_profile_field_shell"
                android:contentDescription="@string/organizer_event_preview_actions_menu"
                android:padding="8dp"
                android:src="@drawable/ic_menu_lines" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/organizer_event_preview_action_menu"
            android:layout_width="220dp"
            android:layout_height="wrap_content"
            android:layout_gravity="end"
            android:layout_marginTop="12dp"
            android:background="@drawable/bg_tickets_tab_shell"
            android:elevation="8dp"
            android:orientation="vertical"
            android:padding="8dp"
            android:visibility="gone">

            <TextView
                android:id="@+id/organizer_event_preview_manage_button"
                android:layout_width="match_parent"
                android:layout_height="46dp"
                android:background="@drawable/bg_profile_field_shell"
                android:drawableStart="@drawable/ic_person"
                android:drawablePadding="10dp"
                android:fontFamily="@font/inter_medium"
                android:gravity="center_vertical"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:text="@string/organizer_event_preview_manage_button"
                android:textColor="@color/text_primary"
                android:textSize="13sp" />

            <TextView
                android:id="@+id/organizer_event_preview_announcement_button"
                android:layout_width="match_parent"
                android:layout_height="46dp"
                android:layout_marginTop="8dp"
                android:background="@drawable/bg_profile_field_shell"
                android:drawableStart="@drawable/ic_notification"
                android:drawablePadding="10dp"
                android:fontFamily="@font/inter_medium"
                android:gravity="center_vertical"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:text="@string/organizer_event_preview_announcement_button"
                android:textColor="@color/text_primary"
                android:textSize="13sp" />

            <TextView
                android:id="@+id/organizer_event_preview_map_button"
                android:layout_width="match_parent"
                android:layout_height="46dp"
                android:layout_marginTop="8dp"
                android:background="@drawable/bg_profile_field_shell"
                android:drawableStart="@drawable/ic_explore"
                android:drawablePadding="10dp"
                android:fontFamily="@font/inter_medium"
                android:gravity="center_vertical"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:text="@string/view_map"
                android:textColor="@color/text_primary"
                android:textSize="13sp" />

            <TextView
                android:id="@+id/organizer_event_preview_coorg_button"
                android:layout_width="match_parent"
                android:layout_height="46dp"
                android:layout_marginTop="8dp"
                android:background="@drawable/bg_profile_field_shell"
                android:drawableStart="@drawable/ic_person"
                android:drawablePadding="10dp"
                android:fontFamily="@font/inter_medium"
                android:gravity="center_vertical"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:text="Select Co-Organizers"
                android:textColor="@color/text_primary"
                android:textSize="13sp" />

            <TextView
                android:id="@+id/organizer_event_preview_invite_button"
                android:layout_width="match_parent"
                android:layout_height="46dp"
                android:layout_marginTop="8dp"
                android:background="@drawable/bg_profile_field_shell"
                android:drawableStart="@drawable/ic_notification"
                android:drawablePadding="10dp"
                android:fontFamily="@font/inter_medium"
                android:gravity="center_vertical"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:text="@string/private_event_invite_menu_button"
                android:textColor="@color/text_primary"
                android:textSize="13sp"
                android:visibility="gone" />
        </LinearLayout>

        <TextView
            android:id="@+id/organizer_event_preview_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="22dp"
            android:textAppearance="@style/TextAppearance.Breezeseas.ScreenTitle"
            android:text="@string/organizer_event_preview_loading"
            android:textSize="30sp" />

        <TextView
            android:id="@+id/organizer_event_preview_subtitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:fontFamily="@font/inter_regular"
            android:lineSpacingExtra="2dp"
            android:text="@string/organizer_event_preview_subtitle_text"
            android:textColor="@color/text_secondary"
            android:textSize="15sp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="22dp"
            android:background="@drawable/bg_welcome_hero_shell"
            android:elevation="10dp"
            android:orientation="vertical"
            android:padding="20dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:fontFamily="@font/inter_medium"
                android:text="@string/create_event_poster_label"
                android:textColor="@color/text_primary"
                android:textSize="13sp" />

            <FrameLayout
                android:id="@+id/organizer_event_preview_poster_card"
                android:layout_width="match_parent"
                android:layout_height="220dp"
                android:layout_marginTop="10dp"
                android:background="@drawable/bg_profile_field_shell"
                android:foreground="?attr/selectableItemBackgroundBorderless">

                <ImageView
                    android:id="@+id/organizer_event_preview_poster"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:contentDescription="@string/organizer_event_preview_poster"
                    android:scaleType="centerCrop"
                    android:src="@drawable/ic_image_placeholder" />
            </FrameLayout>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/organizer_event_preview_update_poster_button"
                style="@style/Widget.Breezeseas.Button.Secondary"
                android:layout_width="wrap_content"
                android:layout_height="@dimen/button_small_height"
                android:layout_marginTop="14dp"
                android:text="@string/organizer_event_preview_update_poster"
                android:textSize="14sp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:fontFamily="@font/inter_medium"
                android:text="@string/create_event_name_label"
                android:textColor="@color/text_primary"
                android:textSize="13sp" />

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:background="@drawable/bg_profile_field_shell"
                android:paddingStart="14dp"
                android:paddingTop="13dp"
                android:paddingEnd="14dp"
                android:paddingBottom="13dp">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/organizer_event_preview_name_input"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@null"
                    android:fontFamily="@font/inter_regular"
                    android:hint="@string/create_event_name_hint"
                    android:inputType="textCapSentences"
                    android:padding="0dp"
                    android:textColor="@color/text_primary"
                    android:textColorHint="@color/text_secondary"
                    android:textSize="15sp" />
            </FrameLayout>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:fontFamily="@font/inter_medium"
                android:text="@string/organizer_event_preview_registration_label"
                android:textColor="@color/text_primary"
                android:textSize="13sp" />

            <LinearLayout
                android:id="@+id/organizer_event_preview_reg_period_button"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:baselineAligned="false"
                android:orientation="horizontal">

                <FrameLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="8dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_profile_field_shell"
                    android:paddingStart="14dp"
                    android:paddingTop="13dp"
                    android:paddingEnd="14dp"
                    android:paddingBottom="13dp">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/organizer_event_preview_reg_from_input"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@null"
                        android:clickable="true"
                        android:focusable="false"
                        android:fontFamily="@font/inter_regular"
                        android:hint="@string/create_event_from"
                        android:padding="0dp"
                        android:textColor="@color/text_primary"
                        android:textColorHint="@color/text_secondary"
                        android:textSize="15sp" />
                </FrameLayout>

                <FrameLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:background="@drawable/bg_profile_field_shell"
                    android:paddingStart="14dp"
                    android:paddingTop="13dp"
                    android:paddingEnd="14dp"
                    android:paddingBottom="13dp">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/organizer_event_preview_reg_to_input"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@null"
                        android:clickable="true"
                        android:focusable="false"
                        android:fontFamily="@font/inter_regular"
                        android:hint="@string/create_event_to"
                        android:padding="0dp"
                        android:textColor="@color/text_primary"
                        android:textColorHint="@color/text_secondary"
                        android:textSize="15sp" />
                </FrameLayout>
            </LinearLayout>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:fontFamily="@font/inter_medium"
                android:text="@string/create_event_capacity_label"
                android:textColor="@color/text_primary"
                android:textSize="13sp" />

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:background="@drawable/bg_profile_field_shell"
                android:paddingStart="14dp"
                android:paddingTop="13dp"
                android:paddingEnd="14dp"
                android:paddingBottom="13dp">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/organizer_event_preview_capacity_input"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@null"
                    android:fontFamily="@font/inter_regular"
                    android:hint="@string/create_event_capacity_hint"
                    android:inputType="number"
                    android:padding="0dp"
                    android:textColor="@color/text_primary"
                    android:textColorHint="@color/text_secondary"
                    android:textSize="15sp" />
            </FrameLayout>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:fontFamily="@font/inter_medium"
                android:text="@string/create_event_waiting_list_capacity_label"
                android:textColor="@color/text_primary"
                android:textSize="13sp" />

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:background="@drawable/bg_profile_field_shell"
                android:paddingStart="14dp"
                android:paddingTop="13dp"
                android:paddingEnd="14dp"
                android:paddingBottom="13dp">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/organizer_event_preview_waiting_list_capacity_input"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@null"
                    android:fontFamily="@font/inter_regular"
                    android:hint="@string/create_event_waiting_list_capacity_hint"
                    android:inputType="number"
                    android:padding="0dp"
                    android:textColor="@color/text_primary"
                    android:textColorHint="@color/text_secondary"
                    android:textSize="15sp" />
            </FrameLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:background="@drawable/bg_profile_field_shell"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingStart="16dp"
                android:paddingTop="14dp"
                android:paddingEnd="16dp"
                android:paddingBottom="14dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/inter_medium"
                        android:text="@string/create_event_geo_label"
                        android:textColor="@color/text_primary"
                        android:textSize="14sp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:fontFamily="@font/inter_regular"
                        android:text="@string/create_event_geo_hint"
                        android:textColor="@color/text_secondary"
                        android:textSize="13sp" />
                </LinearLayout>

                <com.google.android.material.switchmaterial.SwitchMaterial
                    android:id="@+id/organizer_event_preview_geo_switch"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    app:thumbTint="@color/profile_switch_thumb_color"
                    app:trackTint="@color/profile_switch_track_color" />
            </LinearLayout>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:fontFamily="@font/inter_medium"
                android:text="@string/organizer_event_preview_about_label"
                android:textColor="@color/text_primary"
                android:textSize="13sp" />

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:background="@drawable/bg_profile_field_shell"
                android:paddingStart="14dp"
                android:paddingTop="13dp"
                android:paddingEnd="14dp"
                android:paddingBottom="13dp">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/organizer_event_preview_details_input"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@null"
                    android:fontFamily="@font/inter_regular"
                    android:gravity="top"
                    android:hint="@string/create_event_details_hint"
                    android:inputType="textCapSentences|textMultiLine"
                    android:minLines="5"
                    android:padding="0dp"
                    android:textColor="@color/text_primary"
                    android:textColorHint="@color/text_secondary"
                    android:textSize="15sp" />
            </FrameLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="22dp"
                android:baselineAligned="false"
                android:orientation="horizontal">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/organizer_event_preview_save_button"
                    style="@style/Widget.Breezeseas.Button.Primary"
                    android:layout_width="0dp"
                    android:layout_height="54dp"
                    android:layout_marginEnd="6dp"
                    android:layout_weight="1"
                    android:text="@string/organizer_event_preview_save_button"
                    android:textSize="15sp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/organizer_event_preview_delete_button"
                    style="@style/Widget.Breezeseas.Button.Destructive"
                    android:layout_width="0dp"
                    android:layout_height="54dp"
                    android:layout_marginStart="6dp"
                    android:layout_weight="1"
                    android:text="@string/organizer_event_preview_delete_button"
                    android:textSize="14sp" />
            </LinearLayout>

            <include
                layout="@layout/include_event_comments_section" />
        </LinearLayout>
    </LinearLayout>
</androidx.core.widget.NestedScrollView>
